   "source": [
    "#Ghost Revenue is revenue that we cannot trace back to a client.\n",
    "#We treat our Ghost clients as one client and we name it Anon ( for Anonymous).\n",
    "df[\"CustomerID\"] = df[\"CustomerID\"].fillna(\"Anon\")\n",
    "#For unknown invoice number and stock code and country we could simply set that to -1, because it isnt used in out calculations(Those that have a negative quantity and are unknown we set them to C-1 so that we know its a return).\n",
    "df.loc[(df['InvoiceNo'].isna()) & (df['Quantity'] > 0), 'InvoiceNo'] = -1\n",
    "df.loc[(df['InvoiceNo'].isna()) & (df['Quantity'] < 0), 'InvoiceNo'] = \"C-1\"\n",
    "df[\"StockCode\"] = df[\"StockCode\"].fillna(-1)\n",
    "#Same thing for Country and Description but we set to an empty string as they are strings.\n",
    "df[\"Country\"] = df[\"Country\"].fillna(\"\")\n",
    "df[\"Description\"] = df[\"Description\"].fillna(\"\")\n",
    "#For other empty values we can simply remove the row, because setting it to a values like 0 is unreliable and could impact the sum.\n",
    "df = df.dropna()"
   ]
